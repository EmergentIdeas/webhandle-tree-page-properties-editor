<div class="menu-set-editor-frame">
	<div class="tree-side">
		<div class="menu-controls">
		</div>
		<div class="treebox">

		</div>
		<div class="tree-controls">
			<button type="button" class="btn create-folder" title="create new folder">
				<span class="material-icons thumbnail-icon">
					create_new_folder
				</span>
			</button>
			<button type="button" class="btn create-item" title="create new page">
