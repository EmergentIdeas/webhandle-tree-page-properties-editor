					save_as
				</span>
			</button>
			<button type="button" class="btn delete-item" title="delete selected item">
				<span class="material-icons thumbnail-icon">
					delete
				</span>
			</button>
		</div>
	</div>
	<div class="node-view">

	</div>
</div>
